{
  "$schema": "https://raw.githubusercontent.com/nicco-io/tauri-plugin-upload/tauri-v2/schema/tauri.conf.json",
  "productName": "Ultimate Toolkit",
  "version": "0.1.0",
  "identifier": "com.egebulut.ultimate-toolkit",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Ultimate Toolkit",
        "width": 1100,
        "height": 740,
        "minWidth": 880,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/egebulut/ultimate_toolkit_by_egebulut/releases/latest/download/update.json"
      ],
      "pubkey": ""
    }
  }
}
